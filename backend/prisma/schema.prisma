datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum LoanStatus {
  pending
  approved
  rejected
}

model Application {
  id                 String     @id @default(uuid()) @db.Uuid
  applicant_name     String     @db.VarChar(255)
  mobile_number      String     @db.VarChar(15)
  loan_amount        Decimal    @db.Decimal(12, 2)
  loan_purpose       String     @db.Text
  preferred_language String     @db.VarChar(50)
  status             LoanStatus @default(pending)
  created_at         DateTime   @default(now()) @db.Timestamptz(6)

  @@map("applications")
}
